rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    // --- Matches ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other users
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) &&
                       isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin', 'xp', 'streak']);
    }

    match /users/{userId}/resumes/{resumeId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(resumeId);
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['fileName', 'atsScore', 'analysis']);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/interviews/{interviewId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(interviewId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/submissions/{submissionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(submissionId);
    }
  }
}
